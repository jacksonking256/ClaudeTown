# ClaudeTown environment — copy to .env.local and fill in.
# These are FRONTEND (Vite) values. Backend secrets (ANTHROPIC_API_KEY, the
# COMPLETIONS_/EMBEDDING_ provider vars, OLLAMA_*) are set on the Convex
# deployment instead, e.g.:
#   npx convex env set COMPLETIONS_PROVIDER haiku
#   npx convex env set ANTHROPIC_API_KEY sk-ant-...
#
# Vite needs the deployment URL:
VITE_CONVEX_URL=

# ---------------------------------------------------------------------------
# Backend (Convex) env vars — set with `npx convex env set <NAME> <VALUE>`.
# Listed here for reference only; do NOT put secrets in a committed file.
# ---------------------------------------------------------------------------
#
# Completions provider — the one-line switch (default: ollama / fully local):
#   COMPLETIONS_PROVIDER=ollama            # free local dev (needs Ollama)
#   COMPLETIONS_PROVIDER=haiku             # Claude Haiku for quality
#
# Haiku mode (COMPLETIONS_PROVIDER=haiku):
#   ANTHROPIC_API_KEY=sk-ant-...           # required, never hardcode
#   ANTHROPIC_CHAT_MODEL=claude-haiku-4-5  # optional override
#   ANTHROPIC_BASE_URL=https://api.anthropic.com  # optional override
#
# Ollama mode (COMPLETIONS_PROVIDER=ollama):
#   OLLAMA_HOST=http://127.0.0.1:11434
#   OLLAMA_MODEL=llama3
#
# Embeddings — ALWAYS a separate provider (Anthropic has no embeddings API).
# Default is local Ollama mxbai-embed-large (1024-dim). Keep it running even
# in Haiku mode. EMBEDDING_DIMENSION must match the model's output dim.
#   EMBEDDING_PROVIDER=ollama
#   OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
#   # EMBEDDING_DIMENSION=1024              # only change if you change the model
#
# Free plumbing test (no network, canned responses):
#   LLM_STUB=1                             # or COGNITION_DRY_RUN=1
